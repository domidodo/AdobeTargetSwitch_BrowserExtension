{
  "manifest_version": 3,
  "name": "AdobeTargetSwitch",
  "version": "1.0",
  "permissions": [
	"scripting",
    "activeTab",
    "webRequest",
    "webRequestBlocking"
  ],
  "background": {
    "scripts": [
		"background.js"
	]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
	  "run_at": "document_start"
    }
  ],
  "host_permissions": ["<all_urls>"]
}
